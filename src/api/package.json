{
  "name": "@c6maceye/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx database/migrate.ts",
    "db:seed": "tsx database/seed.ts",
    "db:reset": "tsx database/reset.ts"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.5.0",
    "@supabase/supabase-js": "^2.49.0",
    "zod": "^3.24.0",
    "jose": "^6.0.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "@turf/turf": "^7.2.0",
    "nanoid": "^5.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "cron": "^3.5.0",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "rate-limiter-flexible": "^5.1.0",
    "undici": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.0",
    "@types/bcryptjs": "^2.4.6",
    "tsx": "^4.19.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "eslint": "^9.18.0"
  }
}
