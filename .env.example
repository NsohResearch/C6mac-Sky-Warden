# ═══════════════════════════════════════════════════
# C6macEye Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_VERSION=v1

# Database (PostgreSQL + PostGIS + TimescaleDB)
DATABASE_URL=postgresql://c6maceye:c6maceye_dev@localhost:5432/c6maceye
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-minimum-32-characters-long-here
JWT_ISSUER=c6maceye
JWT_AUDIENCE=c6maceye-api
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-here

# FAA Integration
FAA_LAANC_API_URL=https://api.faa.gov/laanc
FAA_LAANC_API_KEY=your-faa-laanc-api-key
FAA_LAANC_USS_ID=C6M
FAA_UDDS_URL=https://udds-faa.opendata.arcgis.com

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/3.0

# Mapbox
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@c6maceye.com
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@c6maceye.com

# S3-compatible Storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=c6maceye
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug
